# Copy to .env and fill in. In production (Coolify) set these as environment variables.

# Postgres connection string.
# Local dev (docker-compose): postgresql://journal:journal@localhost:5432/journal?schema=public
# Coolify: use the connection string of the managed Postgres service.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB?schema=public"

# Auth.js secret. Generate with: openssl rand -base64 32
AUTH_SECRET="change-me"

# Seeded admin account. Created on first `prisma db seed` if not already present.
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-me"
ADMIN_NAME="Administrator"

# Public URL of the app (scheme + host, no trailing slash). REQUIRED in production
# behind a reverse proxy (Coolify/Docker) so the Google OAuth redirect_uri is the
# real public URL instead of the container's internal address (http://0.0.0.0:3000).
# In local dev you can leave this blank.
APP_URL="https://app.example.com"

# Google OAuth sign-in (optional — the Google button only shows when both are set).
# Create an OAuth 2.0 Client (type: Web application) in Google Cloud Console and add
# the redirect URI: <APP_URL>/api/auth/google/callback
#   e.g. http://localhost:3000/api/auth/google/callback  and  https://app.example.com/api/auth/google/callback
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# Always-admin emails (comma-separated). amit.rai@celnet.in is included by default.
# Everyone else must match an allowed domain (managed at /admin/auth-domains) and is created as VIEWER.
GOOGLE_ADMIN_EMAILS="amit.rai@celnet.in"
